@page
@model PROYECTO2.Pages.DronesModel
@{
    ViewData["Title"] = "Gestión de Drones";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gestión de Drones</h2>
        <span class="badge bg-secondary rounded-pill p-3">
            Total registrados: <strong>@Model.ListaDronesUI.Count</strong>
        </span>
    </div>

    @if (!string.IsNullOrEmpty(Model.AlertaUI))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.AlertaUI
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Agregar Nuevo Dron</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Agregar">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre del Dron</label>
                            <input type="text" asp-for="NuevoDron" class="form-control" placeholder="Ej. Dron01" required />
                            <small class="text-muted">El nombre debe ser único en el sistema.</small>
                        </div>
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-save me-2"></i>Guardar Dron
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-list-task me-2"></i>Listado de Drones (Alfabético)</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width: 15%;">#</th>
                                <th>Nombre del Dron</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.ListaDronesUI.Count == 0)
                            {
                                <tr>
                                    <td colspan="2" class="text-center text-muted py-5">
                                        <i class="bi bi-robot fs-1 d-block mb-3"></i>
                                        No hay drones registrados en el sistema.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                int index = 1;
                                foreach (var dron in Model.ListaDronesUI)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-muted">@index</td>
                                        <td>@dron.Nombre</td>
                                    </tr>
                                    index++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>